DATABASE_URL="postgresql://user:password@localhost:5432/siteready_ecommerce"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth — generate a strong random string (e.g. openssl rand -base64 32)
AUTH_SECRET="change-me-in-production-must-be-32-chars!!"

# SMTP (leave blank to print OTPs to console in development)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="user@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM='"My Store" <noreply@example.com>'

# Cloudflare R2
R2_ACCOUNT_ID="your_cloudflare_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="your_bucket_name"
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
